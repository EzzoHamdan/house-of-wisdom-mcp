# AI Council MCP — example environment file
#
# Copy this to `.env` (which is gitignored) next to your config.yaml or in the
# directory you launch the server from, then fill in the keys you actually use:
#   cp .env.example .env
#
# The server loads `.env` before it reads any key. A real environment variable
# — e.g. one set in your MCP client's "env" block — always WINS over a value
# here, so this file is only a fallback for local runs.
#
# Two kinds of names live here, matching config.example.yaml:
#   1. AI_COUNCIL_-prefixed names for the built-in provider keys.
#   2. Plain names referenced by ${ENV_VAR} placeholders on model entries.

# --- Provider-level keys (provider: openai / openrouter) --------------------
# Read directly by the server via the AI_COUNCIL_ prefix.
AI_COUNCIL_OPENAI_API_KEY=sk-...
AI_COUNCIL_OPENROUTER_API_KEY=sk-or-...

# --- Per-model keys referenced by ${ENV_VAR} placeholders -------------------
# Only needed if you enable the matching provider: custom entry and write
# `api_key: "${DEEPSEEK_API_KEY}"` (etc.) on it in config.yaml.
DEEPSEEK_API_KEY=sk-...
# PERPLEXITY_API_KEY=...
# GROQ_API_KEY=...
